# ─────────────────────────────────────────────
# OpenHarness — Environment variables
# Copy to .env and fill in your values.
# ─────────────────────────────────────────────

# ── Option A: Anthropic cloud (default) ──────
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5
# ANTHROPIC_BASE_URL=

# ── Option B: Ollama local model ─────────────
# 1. Make sure Ollama is running on your host:  ollama serve
# 2. Pull a model that supports tool_use:       ollama pull llama3.2
# 3. Uncomment and set the three lines below,
#    then comment out Option A's ANTHROPIC_API_KEY.
#
# ANTHROPIC_API_KEY=openharness-local
# ANTHROPIC_BASE_URL=http://litellm-proxy:4000
# ANTHROPIC_MODEL=llama3.2
#
# Available model names (must match docker/litellm-config.yaml):
#   llama3.2  llama3.1  llama3.3  mistral  qwen2.5-coder  deepseek-r1

# ── Option C: Other Anthropic-compatible ─────
# ANTHROPIC_BASE_URL=https://api.moonshot.cn/anthropic
# ANTHROPIC_API_KEY=your_kimi_api_key
# ANTHROPIC_MODEL=kimi-k2.5
